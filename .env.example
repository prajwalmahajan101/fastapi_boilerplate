# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Application ---
APP_ENVIRONMENT=dev

# --- Database ---
DB_HOST=ChangeMe       # "postgres" inside docker compose, "localhost" otherwise
DB_PORT=5432
DB_USER=ChangeMe
DB_PASSWORD=ChangeMe
DB_NAME=app

# --- Redis (JSON mapping of alias -> url) ---
# Aliases referenced by the resilience layer (cache / circuit breaker /
# rate limit) all default to "default". Add more aliases to isolate
# backends. If Redis is unreachable the resilience layer degrades to an
# in-memory fallback with a warning.
REDIS_URLS={"default":"redis://ChangeMe:6379/0"}

# --- Encryption ---
# Master key for the EncryptedString column type and core.utils.crypto.
# Rotating this invalidates every ciphertext, so treat it as long-lived
# and store it in your secrets manager. Required only if you use
# EncryptedString columns or the FernetCipher helper.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FIELD_ENCRYPTION_KEY=ChangeMe

# General-purpose app secret (token signing, etc.).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
# SECRET_KEY=ChangeMe

# --- AWS (optional — Secrets Manager / S3 / SES) ---
# When AWS_SECRET_NAME is set, that secret blob is the highest-priority
# settings source (above env vars and .env). Leave unset for local dev.
# AWS_REGION=ap-south-1
# AWS_SECRET_NAME=
# S3_DEFAULT_BUCKET=
# SES_DEFAULT_SENDER=

# --- CORS (off by default) ---
# Enable only if a browser needs to call this service. When enabled, list
# every allowed origin/method/header explicitly — the defaults are empty
# so a misconfigured deploy never accidentally exposes the API to "*".
#
# CORS_ENABLED=true
# CORS_ALLOW_ORIGINS=["https://app.example.com"]
# CORS_ALLOW_METHODS=["GET","POST","PATCH","DELETE"]
# CORS_ALLOW_HEADERS=["Content-Type","X-Request-ID"]
# CORS_ALLOW_CREDENTIALS=false

# --- OpenAPI docs (off by default) ---
# /docs (Swagger UI), /redoc, and /openapi.json. Off by default so
# production doesn't ship a public schema dump; enable in dev / staging.
OPENAPI_DOCS_ENABLED=true

# --- API audit log ---
# Backend for the fire-and-forget request/response audit log.
# "postgres" persists to the api_logs table; "noop" disables persistence.
# API_LOG_BACKEND=postgres

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
