# Production dependencies.
#
# Edit this file, then run `pip-compile requirements/base.in` (or let the
# pre-commit hook do it) to regenerate `requirements/base.txt`.

# Web framework
fastapi
uvicorn[standard]

# Settings & validation
pydantic
pydantic-settings

# Database (async Postgres)
sqlalchemy[asyncio]
asyncpg

# Migrations
alembic

# Redis (async client lives in `redis.asyncio`)
redis

# AWS (Secrets Manager, S3, SES)
boto3

# Outbound HTTP (third-party APIs, used in src/core/utils/http_client.py)
aiohttp

# Field-level Fernet encryption
cryptography

# Background tasks — Celery (Redis broker via the redis dep above)
celery

# Auth — JWT (for the JWT auth provider) and Authlib (Google OAuth client)
# Both are imported lazily; deployments that disable a provider can pin
# these to a no-op by removing them from the project's actual requirements
# file. Kept here so the boilerplate-default `auth_enabled_providers`
# combinations all work out of the box.
PyJWT
authlib
itsdangerous  # Authlib StarletteOAuth2App needs SessionMiddleware

# Process-local circuit breaker tier — selected by
# `circuit_breaker_backend="pybreaker"`. Imported lazily so deployments
# that stay on the redis / memory tiers do not pay the cost.
pybreaker
